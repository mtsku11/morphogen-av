    "range": {
      "start_seconds": 0.0,
      "duration_seconds": 4.0
    }
  },
  "graph": {
    "nodes": [
      {
        "id": "source_a",
        "label": "Source A",
        "kind": {
          "type": "source",
          "source_id": "source-a",
          "role": "modulator"
        }
      },
      {
        "id": "source_b",
        "label": "Source B",
        "kind": {
          "type": "source",
          "source_id": "source-b",
          "role": "carrier"
        }
      },
      {
        "id": "analysis_optical_flow_a",
