  },
  "sources": [
    {
      "id": "source-a",
      "label": "Source A synthetic modulator",
      "role": "modulator",
      "uri": "file://replace-with-modulator.mov"
    },
    {
      "id": "source-b",
      "label": "Source B synthetic carrier",
      "role": "carrier",
      "uri": "file://replace-with-carrier.mov"
    }
  ],
  "timeline": {
    "frame_rate": 24.0,
